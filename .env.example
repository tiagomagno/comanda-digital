# Variáveis de Ambiente - Sistema de Comandas Digitais
# Copie este arquivo para .env e preencha com seus valores

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://usuario:senha@localhost:5432/comanda_digital
DB_HOST=localhost
DB_PORT=5432
DB_NAME=comanda_digital
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# ============================================
# REDIS (Cache e Sessões)
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# APPLICATION
# ============================================
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# ============================================
# JWT & SECURITY
# ============================================
JWT_SECRET=sua_chave_secreta_muito_forte_aqui
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# FRONTEND
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# ============================================
# QR CODE
# ============================================
QR_CODE_BASE_URL=http://localhost:3000/comanda

# ============================================
# UPLOAD
# ============================================
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp

# ============================================
# EMAIL (Opcional - para notificações futuras)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_app

# ============================================
# SENTRY (Monitoramento de erros - Opcional)
# ============================================
SENTRY_DSN=

# ============================================
# MODO OFFLINE
# ============================================
OFFLINE_MODE_ENABLED=true
SYNC_INTERVAL=30000
