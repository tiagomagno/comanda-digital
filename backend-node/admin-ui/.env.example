# URL da API quando o painel é servido em outro host (ex.: build em CDN).
# Em dev com npm run dev (porta 5173) não é necessária: o proxy usa a porta do backend.
# VITE_API_URL=http://localhost:3001

# Em dev, proxy do Vite redireciona /api e /uploads para este endereço (opcional; padrão: 3001).
# VITE_DEV_PROXY_TARGET=http://localhost:3001
