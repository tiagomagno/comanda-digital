<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel – Notícias 360</title>
    <style>
        * { box-sizing: border-box; }
        body { font-family: system-ui, -apple-system, sans-serif; margin: 0; background: #f8fafc; color: #1e293b; }
        .header { background: #fff; border-bottom: 1px solid #e2e8f0; padding: 1rem 1.5rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; }
        .header h1 { margin: 0; font-size: 1.25rem; color: #004796; }
        .header a { color: #004796; text-decoration: none; font-size: 0.875rem; font-weight: 500; }
        .header a:hover { text-decoration: underline; }
        .header .links { display: flex; gap: 1rem; align-items: center; }
        .container { max-width: 1200px; margin: 0 auto; padding: 1.5rem; }
        table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 3px rgba(0,0,0,.08); }
        th, td { padding: 0.75rem 1rem; text-align: left; border-bottom: 1px solid #f1f5f9; }
        th { background: #f8fafc; font-weight: 600; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; }
        tr:hover td { background: #f8fafc; }
        .status { display: inline-block; padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600; }
        .status.rascunho { background: #f1f5f9; color: #475569; }
        .status.em_revisao { background: #fef3c7; color: #92400e; }
        .status.publicado { background: #dcfce7; color: #166534; }
        .status.arquivado { background: #e2e8f0; color: #475569; }
        a.link { color: #004796; text-decoration: none; font-weight: 500; }
        a.link:hover { text-decoration: underline; }
        .btn { display: inline-block; padding: 0.5rem 1rem; background: #004796; color: #fff; border-radius: 6px; font-size: 0.875rem; font-weight: 500; text-decoration: none; }
        .btn:hover { background: #003d82; }
        .btn.outline { background: transparent; color: #004796; border: 1px solid #004796; }
        .empty { text-align: center; padding: 3rem; color: #64748b; }
    </style>
</head>
<body>
    <header class="header">
        <h1>Painel Admin – Notícias 360</h1>
        <div class="links">
            <a href="/admin/dashboard">Notícias</a>
            <a href="/admin/logout">Sair</a>
            <a href="/" target="_blank">Ver site →</a>
        </div>
    </header>
    <main class="container">
        <p style="margin-bottom: 1rem;"><a href="/redacao" class="btn">+ Nova notícia</a> <small style="color:#64748b;">(formulário no frontend; em breve só no painel)</small></p>
        <% if (noticias && noticias.length > 0) { %>
        <table>
            <thead>
                <tr>
                    <th>Título</th>
                    <th>Editoria</th>
                    <th>Status</th>
                    <th>Atualizado</th>
                </tr>
            </thead>
            <tbody>
                <% noticias.forEach(function(n) { %>
                <tr>
                    <td><a class="link" href="/<%= n.slug %>" target="_blank"><%= n.titulo %></a></td>
                    <td><%= n.editoria ? n.editoria.nome : '—' %></td>
                    <td><span class="status <%= n.status || 'rascunho' %>"><%= (n.status || 'rascunho').replace('_', ' ') %></span></td>
                    <td><%= n.updatedAt ? new Date(n.updatedAt).toLocaleDateString('pt-BR') : '—' %></td>
                </tr>
                <% }); %>
            </tbody>
        </table>
        <% } else { %>
        <div class="empty">Nenhuma notícia no banco. Use o seed (<code>npm run seed</code>) ou crie pela API / redação.</div>
        <% } %>
    </main>
</body>
</html>
